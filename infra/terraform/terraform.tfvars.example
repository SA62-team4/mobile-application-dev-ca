# @author Tiong Zhong Cheng
# Copy to terraform.tfvars (gitignored). Tokens come from environment variables.

# Required.
ssh_key_name = "your-do-ssh-key-name" # name of an SSH key already in your DO account

# Droplet defaults.
region = "sgp1" # sgp1 | nyc3 | fra1 | ...
# g-4vcpu-16gb gives more Ollama headroom but is restricted on new DO accounts.
droplet_size  = "s-4vcpu-8gb"
droplet_image = "ubuntu-24-04-x64"
droplet_name  = "wellness-prod"
project_name  = "Wellness App"

# SonarQube droplet.
sonar_droplet_size = "s-2vcpu-4gb"
sonar_droplet_name = "wellness-sonar"

# Optional DNS.
# true creates <subdomain>.<domain> in DO DNS; false uses external DNS.
manage_dns = true
domain     = "example.com"
subdomain  = "api"          # FQDN becomes api.example.com
sonar_subdomain = "sonar"   # FQDN becomes sonar.example.com

# DuckDNS alternative:
#   manage_dns = false
#   set GitHub Variable API_DOMAIN=<name>.duckdns.org
