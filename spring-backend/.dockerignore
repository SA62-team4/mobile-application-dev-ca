# .dockerignore tells Docker which files to EXCLUDE when sending the build
# context to the Docker daemon. A smaller context = faster builds.

# Maven build output — these are generated by 'mvn package' and should never
# be sent to Docker. The Dockerfile re-runs Maven inside the container.
target/

# Git metadata — not needed inside the image.
.git/
.github/

# IDE and OS files — these are developer machine artefacts.
.idea/
*.iml
.vscode/
.DS_Store

# Documentation — not needed to run the application.
*.md
docs/

# Local environment files — NEVER copy secrets into images.
.env
.env.*
