# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in real values.
#
# The .env file is intentionally excluded from git (see .gitignore).
# NEVER commit real secrets to source control.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
# The database name, user, and passwords that MySQL will create on first boot.
MYSQL_DATABASE=wellness_app
MYSQL_USER=wellness_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# The host port that your laptop uses to reach MySQL.
# Default is 3307 to avoid clashing with a local MySQL on 3306.
# Container-to-container traffic always uses mysql:3306.
MYSQL_HOST_PORT=3307

# ── Spring Boot Backend ───────────────────────────────────────────────────────
# JDBC URL for Spring Boot. "mysql" is the Docker Compose service name, which
# Docker's internal DNS resolves to the MySQL container's IP address.
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/wellness_app
SPRING_DATASOURCE_USERNAME=wellness_user
SPRING_DATASOURCE_PASSWORD=change_me

# The host port your laptop uses to reach the Spring Boot API.
SPRING_HOST_PORT=8080

# ── JWT Authentication ────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 random characters. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# How long a login token stays valid, in seconds (86400 = 24 hours).
JWT_EXPIRY_SECONDS=86400

# ── Python AI Service ─────────────────────────────────────────────────────────
# The internal URL Spring Boot uses to reach the AI service inside Docker.
AI_SERVICE_URL=http://python-ai-service:8000

# The host port your laptop uses to reach the FastAPI AI service directly.
AI_SERVICE_HOST_PORT=8000

# ── Internal Service Security ─────────────────────────────────────────────────
# A shared secret that the Python AI service uses when calling back to Spring
# Boot's /api/internal/** endpoints. Generate one with: openssl rand -hex 24
INTERNAL_SERVICE_TOKEN=replace_with_internal_token

# ── .NET Backup Backend ───────────────────────────────────────────────────────
DOTNET_BACKEND_HOST_PORT=8082
DOTNET_CONNECTION_STRING=Server=mysql;Port=3306;Database=wellness_app;User=wellness_user;Password=change_me;TreatTinyAsBoolean=true;

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
# The URL the Python AI service uses to reach Ollama inside Docker.
OLLAMA_BASE_URL=http://ollama:11434

# The host port your laptop uses to reach Ollama directly (e.g. with curl).
OLLAMA_HOST_PORT=11434

# The model used to generate text responses (chat + recommendations).
OLLAMA_GENERATION_MODEL=llama3.2:3b

# The model used to turn text into vector embeddings for semantic search.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB (Vector Database) ────────────────────────────────────────────────
# Where ChromaDB stores its index files inside the python-ai-service container.
# This path is mounted to the chroma-data Docker volume.
CHROMA_PERSIST_DIR=/data/chroma

# ── Adminer (Database UI) ─────────────────────────────────────────────────────
ADMINER_HOST_PORT=8081
