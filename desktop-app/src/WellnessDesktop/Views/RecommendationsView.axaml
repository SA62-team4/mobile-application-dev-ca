<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WellnessDesktop.ViewModels"
             xmlns:m="clr-namespace:WellnessDesktop.Models"
             x:Class="WellnessDesktop.Views.RecommendationsView"
             x:DataType="vm:RecommendationsViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="8">

    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
      <StackPanel Grid.Column="0">
        <TextBlock Text="AI recommendations" FontSize="18" FontWeight="Bold" />
        <TextBlock Text="Generated by the Python wellness agent from your recent records."
                   Foreground="#777" />
      </StackPanel>
      <Button Grid.Column="1" Content="Generate" Command="{Binding GenerateCommand}"
              IsEnabled="{Binding !IsGenerating}" Classes="accent" VerticalAlignment="Center" />
    </Grid>

    <!-- Error banner (own row, never overlaps content) -->
    <Border Grid.Row="1" Margin="0,0,0,8" Padding="10,8" CornerRadius="6"
            Background="#FDECEA" BorderBrush="#F5C6CB" BorderThickness="1"
            IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" TextWrapping="Wrap" />
    </Border>

    <Panel Grid.Row="2">
      <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsLoading}" />
      <ProgressBar IsIndeterminate="True" Height="4" IsVisible="{Binding IsGenerating}" />
    </Panel>

    <Panel Grid.Row="3">
      <TextBlock Text="No recommendations yet. Click Generate to create one."
                 HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#777"
                 IsVisible="{Binding IsEmpty}" />

      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Recommendations}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="m:RecommendationDto">
              <Border Margin="0,0,0,10" Padding="12" CornerRadius="8"
                      BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding TrendSummary}" Foreground="#555" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding RecommendationText}" TextWrapping="Wrap" />
                  <ItemsControl ItemsSource="{Binding ActionItems}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="x:String">
                        <TextBlock TextWrapping="Wrap">
                          <Run Text="•  " /><Run Text="{Binding}" />
                        </TextBlock>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Panel>
  </Grid>
</UserControl>
