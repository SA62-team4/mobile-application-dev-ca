<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:orientation="vertical">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Privacy &amp; data"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_app_card"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How your data is handled"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:text="• AI runs locally. Recommendations and the wellness chatbot are generated on a self-hosted Ollama model. Your entries are never sent to any third-party AI cloud.\n\n• You control your data. Export a full copy of everything stored about you at any time, or remove it.\n\n• Deactivate is reversible. Your account is hidden and sign-in is blocked, but your records, recommendations and chat history are kept. Reactivate anytime by signing in again.\n\n• Delete is permanent. This erases your account and all associated data from the server and cannot be undone — export first if you want a copy.\n\nNote: your data is stored securely on the app's server database, not only on this device." />
            </LinearLayout>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:padding="12dp"
                android:layout_marginBottom="14dp"
                android:textColor="@color/text_on_primary"
                android:background="@drawable/bg_status_success" />

            <Button
                android:id="@+id/exportButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="Export my data"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/deactivateButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Deactivate account (reversible)"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/deleteButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_destructive"
                android:text="Delete account permanently"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
