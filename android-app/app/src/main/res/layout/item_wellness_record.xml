<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@color/bg_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/recordDateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/record_sample_date"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sleepText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/record_sample_sleep"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/exerciseText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/record_sample_exercise"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/moodText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/record_sample_mood"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/notesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/record_sample_notes"
        android:textColor="@color/text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/editButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:contentDescription="@string/cd_edit_record"
            android:text="@string/action_edit" />

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/cd_delete_record"
            android:text="@string/action_delete" />

    </LinearLayout>

</LinearLayout>
