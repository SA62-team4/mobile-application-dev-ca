<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:orientation="vertical">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Add record"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/dateInput"
                android:text="@string/label_record_date"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/dateInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_text_field"
                android:clickable="true"
                android:focusable="false"
                android:hint="@string/hint_pick_date"
                android:inputType="datetime"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/sleepInput"
                android:text="@string/label_sleep_hours"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/sleepInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_text_field"
                android:hint="@string/hint_sleep_hours"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/weightInput"
                android:text="@string/label_weight_kg"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/weightInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_text_field"
                android:hint="@string/hint_weight_kg"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/exerciseTypeInput"
                android:text="@string/label_exercise_type"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/exerciseTypeInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_text_field"
                android:contentDescription="@string/label_exercise_type"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:prompt="@string/label_exercise_type"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/exerciseMinutesInput"
                android:text="@string/label_exercise_minutes"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/exerciseMinutesInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_text_field"
                android:hint="@string/hint_exercise_minutes"
                android:inputType="number"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/moodInput"
                android:text="@string/label_mood_score"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/moodInput"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_text_field"
                android:hint="@string/hint_mood_score"
                android:inputType="number"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:labelFor="@id/notesInput"
                android:text="@string/label_notes"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/notesInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_text_field"
                android:gravity="top"
                android:hint="@string/hint_notes"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/statusContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button_primary"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/deleteButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_button_destructive"
                android:text="Delete"
                android:textAllCaps="false"
                android:textColor="@color/text_on_primary"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/cancelButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
