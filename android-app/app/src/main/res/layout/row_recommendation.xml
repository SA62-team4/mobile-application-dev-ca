<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_recommendation_card"
    android:layout_marginBottom="14dp">

    <TextView
        android:id="@+id/recTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/recTrendSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/recText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/recActionsLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/recommendation_actions"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/recActionItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/recCreatedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />
</LinearLayout>
