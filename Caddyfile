# Public HTTPS edge. Terminates TLS (auto Let's Encrypt) and proxies to Spring
# Boot over the internal network. Domain comes from $API_DOMAIN (set in .env).
# DNS for $API_DOMAIN must resolve to the droplet before Caddy starts.

{$API_DOMAIN} {
	reverse_proxy spring-backend:8080

	log {
		output stdout
		format console
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		-Server
	}
}
